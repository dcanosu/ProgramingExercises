## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools.

# --- Build results (.NET) ---
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
publish/
# Avoid uploading MSBuild binary logs
*.binlog

# --- Visual Studio Code ---
# Local editor settings (not to be shared)
.vscode/
# Except if you want to share specific tasks or launchers
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- .NET Tools ---
# Package restoration files
project.lock.json
project.fragment.lock.json
.ionide/

# --- macOS Specific files (Apple Silicon) ---
# OS-generated files
.DS_Store
.AppleDouble
.LSOverride
# Temporary swap files
._*

# --- NuGet ---
# Do not upload downloaded packages, they are restored during build
*.nupkg
*.snupkg

# --- Others ---
# Temporary Office or text editor files
~$*
*~
*.log